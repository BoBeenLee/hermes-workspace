{
  "name": "hermes-remote-ops",
  "private": true,
  "version": "0.1.0",
  "description": "Workspace for operating remote Hermes Agent targets.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bash -n bin/hermes-remote && bash -n packages/hermes-remote-cli/bin/hermes-remote",
    "projects": "bin/hermes-remote projects",
    "status:bobeen": "bin/hermes-remote --project bobeen status"
  }
}

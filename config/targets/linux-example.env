# Example Hermes target profile for a Linux host.
#
# This profile is intentionally not runnable as-is. Copy it to a new target
# profile and replace the placeholder host/user/path values.

HERMES_REMOTE_HOST=replace-me-linux-host
HERMES_REMOTE_USER=hermes
HERMES_REMOTE_HOME=/home/hermes
HERMES_REMOTE_OS=linux
HERMES_SERVICE_MANAGER=systemd
HERMES_COMPUTER_USE_BACKEND=none

HERMES_BIN=/home/hermes/.local/bin/hermes
CUA_BIN=
HERMES_CONFIG=/home/hermes/.hermes/config.yaml
HERMES_REMOTE_WORKSPACE=/home/hermes/Workspaces/hermes-workspace
HERMES_WORKSPACE_REPO=git@github.com:BoBeenLee/hermes-workspace.git
HERMES_WORKSPACE_BRANCH=main

# Optional local/self-hosted LLM provider hints. Keep secrets out of target files.
HERMES_LLM_PROVIDER=
HERMES_LLM_BASE_URL=
HERMES_LLM_MODEL=
HERMES_LLM_CONTEXT_LENGTH=65536

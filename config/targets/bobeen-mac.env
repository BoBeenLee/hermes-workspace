# Default Hermes target profile for the current remote macOS host.

HERMES_REMOTE_HOST=bobeen
HERMES_REMOTE_USER=bobeenlee
HERMES_REMOTE_HOME=/Users/bobeenlee
HERMES_REMOTE_OS=macos
HERMES_SERVICE_MANAGER=launchd
HERMES_COMPUTER_USE_BACKEND=cua-driver

HERMES_BIN=/Users/bobeenlee/.local/bin/hermes
CUA_BIN=/Users/bobeenlee/.local/bin/cua-driver
HERMES_CONFIG=/Users/bobeenlee/.hermes/config.yaml
HERMES_REMOTE_WORKSPACE=/Users/bobeenlee/Workspaces/hermes-workspace
HERMES_WORKSPACE_REPO=git@github.com:BoBeenLee/hermes-workspace.git
HERMES_WORKSPACE_BRANCH=main

# Example Hermes target profile for DGX Spark / Linux.
#
# This profile is intentionally an example. Copy it to a real target profile
# and verify the SSH alias, user, and home directory before running commands.
# Do not store passwords, provider keys, OAuth tokens, or auth.json here.

HERMES_REMOTE_HOST=aitopatom-36a9.local
HERMES_REMOTE_USER=bobeenlee
HERMES_REMOTE_HOME=/home/bobeenlee
HERMES_REMOTE_OS=linux
HERMES_SERVICE_MANAGER=systemd
HERMES_COMPUTER_USE_BACKEND=none

HERMES_BIN=/home/bobeenlee/.local/bin/hermes
CUA_BIN=
HERMES_CONFIG=/home/bobeenlee/.hermes/config.yaml
HERMES_REMOTE_WORKSPACE=/home/bobeenlee/Workspaces/hermes-workspace
HERMES_WORKSPACE_REPO=git@github.com:BoBeenLee/hermes-workspace.git
HERMES_WORKSPACE_BRANCH=main

# Optional SSH key for bootstrap scripts. Prefer ~/.ssh/config aliases when possible.
# HERMES_SSH_KEY=~/.ssh/id_ed25519_dgx_spark

# Optional local/self-hosted LLM provider hints. Keep services bound to loopback
# and use SSH tunnels unless the user explicitly approves external exposure.
HERMES_LLM_PROVIDER=vllm
HERMES_LLM_BASE_URL=http://127.0.0.1:8000/v1
HERMES_LLM_MODEL=
HERMES_LLM_CONTEXT_LENGTH=65536

# Example Hermes target profile for a new macOS host.
#
# Copy this file to config/targets/<target>.env and replace the placeholder
# host, user, and path values. Do not store secrets in target profiles.

HERMES_REMOTE_HOST=replace-me-macos-host
HERMES_REMOTE_USER=replace-me-user
HERMES_REMOTE_HOME=/Users/replace-me-user
HERMES_REMOTE_OS=macos
HERMES_SERVICE_MANAGER=launchd
HERMES_COMPUTER_USE_BACKEND=cua-driver

HERMES_BIN=/Users/replace-me-user/.local/bin/hermes
CUA_BIN=/Users/replace-me-user/.local/bin/cua-driver
HERMES_CONFIG=/Users/replace-me-user/.hermes/config.yaml
HERMES_REMOTE_WORKSPACE=/Users/replace-me-user/Workspaces/hermes-workspace
HERMES_WORKSPACE_REPO=git@github.com:BoBeenLee/hermes-workspace.git
HERMES_WORKSPACE_BRANCH=main

# Optional SSH key for bootstrap scripts. Prefer ~/.ssh/config aliases when possible.
# HERMES_SSH_KEY=~/.ssh/id_ed25519_replace_me

# Optional local/self-hosted LLM provider hints. Keep secrets out of target files.
HERMES_LLM_PROVIDER=
HERMES_LLM_BASE_URL=
HERMES_LLM_MODEL=
HERMES_LLM_CONTEXT_LENGTH=65536

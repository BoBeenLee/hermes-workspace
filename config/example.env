# SSH alias or user@host from your local ~/.ssh/config.
HERMES_REMOTE_HOST=bobeen
HERMES_REMOTE_USER=bobeenlee

# Target behavior.
HERMES_REMOTE_OS=macos
HERMES_SERVICE_MANAGER=launchd
HERMES_COMPUTER_USE_BACKEND=cua-driver

# Remote paths.
HERMES_REMOTE_HOME=/Users/bobeenlee
HERMES_BIN=/Users/bobeenlee/.local/bin/hermes
CUA_BIN=/Users/bobeenlee/.local/bin/cua-driver
HERMES_CONFIG=/Users/bobeenlee/.hermes/config.yaml
HERMES_REMOTE_WORKSPACE=/Users/bobeenlee/Workspaces/hermes-workspace

# Optional SSH options. Keep BatchMode off if your key requires interaction.
SSH_CONNECT_TIMEOUT=8
# Optional explicit key for scripts/hermes/install.sh and doctor.sh.
# HERMES_SSH_KEY=~/.ssh/id_ed25519_bobeenlee_nopass

# Optional local/self-hosted LLM provider hints for operator runbooks.
# Do not store provider API keys or copied Hermes provider config here.
HERMES_LLM_PROVIDER=
HERMES_LLM_BASE_URL=
HERMES_LLM_MODEL=
HERMES_LLM_CONTEXT_LENGTH=65536

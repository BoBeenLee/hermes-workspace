# Optional local overrides for the selected target profile.
#
# Target defaults live in config/targets/<name>.env.
# Select a target with:
#
#   bin/hermes-remote --target bobeen-mac status
#   HERMES_TARGET=bobeen-mac bin/hermes-remote status
#
# Copy this file to .env only for machine-local overrides. Do not commit .env.

# HERMES_TARGET=bobeen-mac
# HERMES_REMOTE_HOST=bobeen
# HERMES_REMOTE_HOME=/Users/bobeenlee
# HERMES_BIN=/Users/bobeenlee/.local/bin/hermes
# CUA_BIN=/Users/bobeenlee/.local/bin/cua-driver
# HERMES_CONFIG=/Users/bobeenlee/.hermes/config.yaml
# HERMES_WORKSPACE_ROOT=/Users/bobeenlee/Workspaces/hermes-workspace

# Optional SSH options. Keep BatchMode off if your key requires interaction.
SSH_CONNECT_TIMEOUT=8

# Copy this file to projects/<project-name>.env for another Hermes target.
#
# Keep secrets out of project profiles. Store SSH keys in ~/.ssh and provider
# secrets on the remote Hermes Mac under ~/.hermes.
HERMES_REMOTE_HOST=your-ssh-alias
HERMES_REMOTE_HOME=/Users/remote-user
HERMES_BIN=/Users/remote-user/.local/bin/hermes
CUA_BIN=/Users/remote-user/.local/bin/cua-driver
HERMES_CONFIG=/Users/remote-user/.hermes/config.yaml
SSH_CONNECT_TIMEOUT=8

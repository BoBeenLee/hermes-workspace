#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET_DIR="$ROOT_DIR/config/targets"

HERMES_TARGET="${HERMES_TARGET:-bobeen-mac}"
args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      if [[ -z "${2:-}" ]]; then
        echo "--target requires a value" >&2
        exit 2
      fi
      HERMES_TARGET="$2"
      shift 2
      ;;
    --target=*)
      HERMES_TARGET="${1#--target=}"
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done
set -- "${args[@]}"

TARGET_PROFILE="$TARGET_DIR/$HERMES_TARGET.env"
if [[ ! -f "$TARGET_PROFILE" ]]; then
  echo "Unknown Hermes target profile: $HERMES_TARGET" >&2
  echo "Expected profile at: $TARGET_PROFILE" >&2
  exit 2
fi

SELECTED_HERMES_TARGET="$HERMES_TARGET"
# shellcheck disable=SC1090
source "$TARGET_PROFILE"

if [[ -f "$ROOT_DIR/.env" ]]; then
  # shellcheck disable=SC1091
  source "$ROOT_DIR/.env"
fi
HERMES_TARGET="$SELECTED_HERMES_TARGET"

: "${HERMES_REMOTE_HOST:?HERMES_REMOTE_HOST is required by target profile}"
: "${HERMES_REMOTE_HOME:?HERMES_REMOTE_HOME is required by target profile}"
: "${HERMES_REMOTE_USER:=}"
: "${HERMES_REMOTE_OS:=macos}"
: "${HERMES_SERVICE_MANAGER:=auto}"
: "${HERMES_COMPUTER_USE_BACKEND:=none}"
: "${HERMES_BIN:=$HERMES_REMOTE_HOME/.local/bin/hermes}"
: "${CUA_BIN=$HERMES_REMOTE_HOME/.local/bin/cua-driver}"
: "${HERMES_CONFIG:=$HERMES_REMOTE_HOME/.hermes/config.yaml}"
: "${HERMES_WORKSPACE_ROOT:=$HERMES_REMOTE_HOME/Workspaces/hermes-workspace}"
: "${HERMES_WORKSPACE_REPO:=git@github.com:BoBeenLee/hermes-workspace.git}"
: "${HERMES_WORKSPACE_BRANCH:=main}"
: "${SSH_CONNECT_TIMEOUT:=8}"

ssh_remote() {
  ssh -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}" "$HERMES_REMOTE_HOST" "$@"
}

remote_bash() {
  ssh_remote "HERMES_TARGET='$HERMES_TARGET' HERMES_REMOTE_HOME='$HERMES_REMOTE_HOME' HERMES_REMOTE_OS='$HERMES_REMOTE_OS' HERMES_SERVICE_MANAGER='$HERMES_SERVICE_MANAGER' HERMES_COMPUTER_USE_BACKEND='$HERMES_COMPUTER_USE_BACKEND' HERMES_BIN='$HERMES_BIN' CUA_BIN='$CUA_BIN' HERMES_CONFIG='$HERMES_CONFIG' HERMES_WORKSPACE_ROOT='$HERMES_WORKSPACE_ROOT' HERMES_WORKSPACE_REPO='$HERMES_WORKSPACE_REPO' HERMES_WORKSPACE_BRANCH='$HERMES_WORKSPACE_BRANCH' bash -s"
}

require_computer_use_backend() {
  if [[ "$HERMES_REMOTE_OS" != "macos" || "$HERMES_COMPUTER_USE_BACKEND" != "cua-driver" ]]; then
    echo "Unsupported command for target '$HERMES_TARGET': computer_use backend is '$HERMES_COMPUTER_USE_BACKEND' on '$HERMES_REMOTE_OS'." >&2
    echo "This command requires macos with HERMES_COMPUTER_USE_BACKEND=cua-driver." >&2
    exit 2
  fi
}

show_config() {
  cat <<CONFIG
HERMES_TARGET=$HERMES_TARGET
HERMES_REMOTE_HOST=$HERMES_REMOTE_HOST
HERMES_REMOTE_USER=$HERMES_REMOTE_USER
HERMES_REMOTE_HOME=$HERMES_REMOTE_HOME
HERMES_REMOTE_OS=$HERMES_REMOTE_OS
HERMES_SERVICE_MANAGER=$HERMES_SERVICE_MANAGER
HERMES_COMPUTER_USE_BACKEND=$HERMES_COMPUTER_USE_BACKEND
HERMES_BIN=$HERMES_BIN
CUA_BIN=$CUA_BIN
HERMES_CONFIG=$HERMES_CONFIG
HERMES_WORKSPACE_ROOT=$HERMES_WORKSPACE_ROOT
HERMES_WORKSPACE_REPO=$HERMES_WORKSPACE_REPO
HERMES_WORKSPACE_BRANCH=$HERMES_WORKSPACE_BRANCH
SSH_CONNECT_TIMEOUT=$SSH_CONNECT_TIMEOUT
CONFIG
}

usage() {
  cat <<'USAGE'
Usage:
  bin/hermes-remote [--target <name>] <command> [args]

Commands:
  config                    Print the resolved target profile.
  check-ssh                 Verify SSH connectivity and core paths.
  status                    Show Hermes, gateway, optional computer_use, Kanban, dashboard, and process state.
  setup-computer-use        Install cua-driver and wire Hermes config/toolset (macOS/cua-driver targets only).
  grant-computer-use        Open CuaDriver permission grant flow (macOS/cua-driver targets only).
  verify-computer-use       Verify permissions, MCP, screen size, and window access (macOS/cua-driver targets only).
  setup-kanban              Initialize Kanban and enable gateway dispatcher config.
  gateway-restart           Restart the Hermes gateway service.
  dashboard-start           Start dashboard on the remote target at 127.0.0.1:9119.
  dashboard-status          Show dashboard status.
  is-working <thread_id>    Decide whether a Discord thread still has active Hermes work.
  tail-thread <thread_id>   Print recent gateway/agent log lines for a Discord thread.
  run <prompt>              Run a remote Hermes one-shot prompt.
  logs                      Print recent gateway, agent, and error logs.

Config:
  Target profiles live under config/targets/<name>.env.
  Use --target <name> or HERMES_TARGET=<name>. Local .env overrides the selected profile.
USAGE
}

check_ssh() {
  remote_bash <<'REMOTE'
set -e
hostname
whoami
date
test -x "$HERMES_BIN" && "$HERMES_BIN" --version || true
if [[ "$HERMES_COMPUTER_USE_BACKEND" == "cua-driver" ]]; then
  test -x "$CUA_BIN" && "$CUA_BIN" --version || true
fi
REMOTE
}

status() {
  remote_bash <<'REMOTE'
set +e
echo '== host =='
hostname
whoami
date
echo "target: $HERMES_TARGET"
echo "os: $HERMES_REMOTE_OS"
echo "service manager: $HERMES_SERVICE_MANAGER"
echo "computer_use backend: $HERMES_COMPUTER_USE_BACKEND"
echo
echo '== hermes status =='
"$HERMES_BIN" status
echo
echo '== gateway =='
"$HERMES_BIN" gateway status
if [[ "$HERMES_COMPUTER_USE_BACKEND" == "cua-driver" ]]; then
  echo
  echo '== computer_use =='
  "$HERMES_BIN" computer-use status
  echo
  echo '== cua permissions =='
  "$CUA_BIN" permissions status
fi
echo
echo '== kanban =='
"$HERMES_BIN" kanban stats
echo
echo '== dashboard =='
"$HERMES_BIN" dashboard --status
echo
echo '== processes =='
(ps -axo pid,etime,stat,command 2>/dev/null || ps -eo pid,etime,stat,command 2>/dev/null) | grep -E 'hermes|gateway|cua-driver' | grep -v grep
REMOTE
}

setup_computer_use() {
  require_computer_use_backend
  ssh_remote "'$HERMES_BIN' computer-use install || true"

  remote_bash <<'REMOTE'
set -euo pipefail

if [[ -f "$HERMES_BIN" ]]; then
  cp "$HERMES_BIN" "$HERMES_BIN.bak-remote-ops-$(date +%Y%m%d%H%M%S)"
  if ! grep -q 'export PATH=.*\.local/bin' "$HERMES_BIN"; then
    python3 - "$HERMES_BIN" "$HERMES_REMOTE_HOME" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
home = sys.argv[2]
text = path.read_text()
line = f'export PATH="{home}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"\n'
if "unset PYTHONHOME\n" in text:
    text = text.replace("unset PYTHONHOME\n", "unset PYTHONHOME\n" + line, 1)
elif line not in text:
    text = text.replace("#!/usr/bin/env bash\n", "#!/usr/bin/env bash\n" + line, 1)
path.write_text(text)
PY
  fi
fi

cp "$HERMES_CONFIG" "$HERMES_CONFIG.bak-remote-ops-$(date +%Y%m%d%H%M%S)"
python3 - "$HERMES_CONFIG" "$CUA_BIN" <<'PY'
from pathlib import Path
import sys

config = Path(sys.argv[1])
cua_bin = sys.argv[2]
text = config.read_text()
lines = text.splitlines()

def find_top_level(name):
    for i, line in enumerate(lines):
        if line == f"{name}:":
            return i
    return -1

if "  cua-driver:" not in text:
    block = [
        "mcp_servers:",
        "  cua-driver:",
        f'    command: "{cua_bin}"',
        '    args: ["mcp"]',
    ]
    mcp_idx = find_top_level("mcp_servers")
    if mcp_idx >= 0:
        lines[mcp_idx + 1:mcp_idx + 1] = block[1:]
    else:
        insert_at = 0
        for i, line in enumerate(lines):
            if line.startswith("credential_pool_strategies:"):
                insert_at = i + 1
                break
        lines[insert_at:insert_at] = block

tool_idx = find_top_level("toolsets")
if tool_idx < 0:
    lines.extend(["toolsets:", "- hermes-cli", "- computer_use"])
else:
    end = tool_idx + 1
    has_computer_use = False
    while end < len(lines):
        line = lines[end]
        if line and not line.startswith((" ", "-")):
            break
        if line.strip() == "- computer_use":
            has_computer_use = True
        end += 1
    if not has_computer_use:
        lines[end:end] = ["- computer_use"]

config.write_text("\n".join(lines) + "\n")
PY
REMOTE

  ssh_remote "'$HERMES_BIN' computer-use status && '$HERMES_BIN' mcp list"
}

grant_computer_use() {
  require_computer_use_backend
  ssh_remote "'$CUA_BIN' permissions grant"
}

verify_computer_use() {
  require_computer_use_backend
  ssh_remote "set +e
open -n -g -a CuaDriver --args serve
sleep 2
echo '== permissions =='
'$CUA_BIN' permissions status
echo
echo '== check_permissions =='
'$CUA_BIN' check_permissions
echo
echo '== mcp =='
'$HERMES_BIN' mcp test cua-driver
echo
echo '== screen =='
'$CUA_BIN' get_screen_size
echo
echo '== visible windows sample =='
'$CUA_BIN' list_windows | head -80"
}

setup_kanban() {
  ssh_remote "'$HERMES_BIN' kanban init"
  remote_bash <<'REMOTE'
set -euo pipefail
cp "$HERMES_CONFIG" "$HERMES_CONFIG.bak-remote-ops-kanban-$(date +%Y%m%d%H%M%S)"
python3 - "$HERMES_CONFIG" <<'PY'
from pathlib import Path
import sys

config = Path(sys.argv[1])
lines = config.read_text().splitlines()

def find_top_level(name):
    for i, line in enumerate(lines):
        if line == f"{name}:":
            return i
    return -1

idx = find_top_level("kanban")
desired = {
    "dispatch_in_gateway": "true",
    "dispatch_interval_seconds": "60",
}
if idx < 0:
    lines.extend(["kanban:"] + [f"  {k}: {v}" for k, v in desired.items()])
else:
    end = idx + 1
    existing = {}
    while end < len(lines):
        line = lines[end]
        if line and not line.startswith(" "):
            break
        stripped = line.strip()
        if ":" in stripped:
            existing[stripped.split(":", 1)[0]] = end
        end += 1
    for key, value in desired.items():
        if key in existing:
            lines[existing[key]] = f"  {key}: {value}"
        else:
            lines[end:end] = [f"  {key}: {value}"]
            end += 1

config.write_text("\n".join(lines) + "\n")
PY
REMOTE
  ssh_remote "'$HERMES_BIN' kanban boards list && '$HERMES_BIN' kanban stats && '$HERMES_BIN' kanban diagnostics"
}

gateway_restart() {
  ssh_remote "'$HERMES_BIN' gateway restart && '$HERMES_BIN' gateway status"
}

dashboard_start() {
  ssh_remote "nohup '$HERMES_BIN' dashboard --no-open --host 127.0.0.1 --port 9119 > '$HERMES_REMOTE_HOME/.hermes/logs/dashboard.log' 2>&1 & sleep 2; '$HERMES_BIN' dashboard --status"
}

dashboard_status() {
  ssh_remote "'$HERMES_BIN' dashboard --status"
}

tail_thread() {
  local thread_id="${1:-}"
  if [[ -z "$thread_id" ]]; then
    echo "thread id required" >&2
    exit 2
  fi
  ssh_remote "grep -R '$thread_id' '$HERMES_REMOTE_HOME/.hermes/logs/gateway.log' '$HERMES_REMOTE_HOME/.hermes/logs/agent.log' '$HERMES_REMOTE_HOME/.hermes/logs/errors.log' 2>/dev/null | tail -160"
}

is_working() {
  local thread_id="${1:-}"
  if [[ -z "$thread_id" ]]; then
    echo "thread id required" >&2
    exit 2
  fi
  ssh_remote "set +e
echo '== recent thread log =='
grep -R '$thread_id' '$HERMES_REMOTE_HOME/.hermes/logs/gateway.log' '$HERMES_REMOTE_HOME/.hermes/logs/agent.log' 2>/dev/null | tail -80
echo
echo '== processes =='
/bin/ps -axo pid,etime,stat,command | /usr/bin/grep -E 'hermes|gateway|cua-driver' | /usr/bin/grep -v grep
echo
echo '== sessions =='
'$HERMES_BIN' sessions list 2>&1 | head -40
echo
echo '== kanban =='
'$HERMES_BIN' kanban stats
'$HERMES_BIN' kanban list --json"
}

run_prompt() {
  local prompt="${1:-}"
  if [[ -z "$prompt" ]]; then
    echo "prompt required" >&2
    exit 2
  fi
  if [[ "$HERMES_COMPUTER_USE_BACKEND" == "cua-driver" ]]; then
    ssh_remote "'$HERMES_BIN' -t computer_use -z $(printf '%q' "$prompt")"
  else
    ssh_remote "'$HERMES_BIN' -z $(printf '%q' "$prompt")"
  fi
}

logs() {
  ssh_remote "echo '== gateway =='; tail -80 '$HERMES_REMOTE_HOME/.hermes/logs/gateway.log'; echo; echo '== agent =='; tail -80 '$HERMES_REMOTE_HOME/.hermes/logs/agent.log'; echo; echo '== errors =='; tail -80 '$HERMES_REMOTE_HOME/.hermes/logs/errors.log'"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  config) show_config "$@" ;;
  check-ssh) check_ssh "$@" ;;
  status) status "$@" ;;
  setup-computer-use) setup_computer_use "$@" ;;
  grant-computer-use) grant_computer_use "$@" ;;
  verify-computer-use) verify_computer_use "$@" ;;
  setup-kanban) setup_kanban "$@" ;;
  gateway-restart) gateway_restart "$@" ;;
  dashboard-start) dashboard_start "$@" ;;
  dashboard-status) dashboard_status "$@" ;;
  is-working) is_working "$@" ;;
  tail-thread) tail_thread "$@" ;;
  run) run_prompt "$@" ;;
  logs) logs "$@" ;;
  ""|-h|--help|help) usage ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
